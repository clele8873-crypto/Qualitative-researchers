rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: test_results
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, length > 0, < 100)
    //   - studentId: string (required, length > 0, < 50)
    //   - scores: map (required, contains newPositivism, originalism, constructivism, criticalTheory as numbers)
    //   - resultTypes: list of strings (required, size > 0, < 5)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == "clele8873@gmail.com" && request.auth.token.email_verified == true;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isValidScores() {
      let scores = request.resource.data.scores;
      return scores is map &&
             scores.keys().hasOnly(['newPositivism', 'originalism', 'constructivism', 'criticalTheory']) &&
             scores.newPositivism is number && scores.newPositivism >= 0 && scores.newPositivism <= 25 &&
             scores.originalism is number && scores.originalism >= 0 && scores.originalism <= 25 &&
             scores.constructivism is number && scores.constructivism >= 0 && scores.constructivism <= 25 &&
             scores.criticalTheory is number && scores.criticalTheory >= 0 && scores.criticalTheory <= 25;
    }

    function isValidResultTypes() {
      let types = request.resource.data.resultTypes;
      return types is list && types.size() > 0 && types.size() <= 4;
    }

    function isValidTestResult() {
      return hasOnlyAllowedFields(['name', 'studentId', 'scores', 'resultTypes', 'createdAt']) &&
             validStringLength('name', 1, 100) &&
             validStringLength('studentId', 1, 50) &&
             isValidScores() &&
             isValidResultTypes() &&
             request.resource.data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /test_results/{resultId} {
      // Anyone can submit a test result (public form)
      allow create: if isValidTestResult();
      
      // Reading is allowed for the admin dashboard (protected by frontend password)
      // Note: In a production app, you should use Firebase Auth for real security.
      allow read: if true;
      
      // No one can update or delete
      allow update, delete: if false;
    }
  }
}
